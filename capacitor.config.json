{
  "appId": "com.lukasjennings.portboss",
  "appName": "Port Boss",
  "webDir": "dist/portboss-portal",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#080d1e",
      "androidSplashResourceName": "splash",
      "showSpinner": false,
      "launchAutoHide": true
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#080d1e"
    }
  }
}
